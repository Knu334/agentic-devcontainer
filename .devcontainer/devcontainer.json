{
  "name": "Claude Code Sandbox",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "remoteUser": "node",
  "forwardPorts": [],
  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code", "eamodio.gitlens"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "bash", "icon": "terminal-bash" },
          "zsh": { "path": "zsh" }
        },
        "remote.autoForwardPorts": false
      }
    }
  },
  "postStartCommand": "/usr/local/bin/init-git.sh && sudo /usr/local/bin/init-firewall.sh && /usr/local/bin/init-context7.sh && /usr/local/bin/init-statusline.sh",
  "waitFor": "postStartCommand"
}
